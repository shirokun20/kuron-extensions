      "keyword_mode": {
        "queryParam": "keyword_mode",
        "type": "select",
        "label": "Keyword Mode",
        "options": [
          {
            "name": "Contain",
            "value": "contains"
          },
          {
            "name": "Start With",
            "value": "start-with"
          },
          {
            "name": "End With",
            "value": "end-with"
          }
        ]
      },
      "artist": {
        "queryParam": "artists[]",
        "type": "text",
        "label": "Artists",
        "placeholder": "Search artists..."
      },
      "author": {
        "queryParam": "authors[]",
        "type": "text",
        "label": "Authors",
        "placeholder": "Search authors..."
      },
      "year_range": {
        "queryParam": "year_range",
        "type": "text",
        "label": "Publish Year",
        "placeholder": "e.g. 2006-2026"
      },
      "chapter_range": {
        "queryParam": "chapter_range",
        "type": "text",
        "label": "Chapters",
        "placeholder": "e.g. 1-345"
      }
    }
  },
  "navigation": {
    "tagQueryMapping": {
      "tag": {
        "mode": "name"
      },
      "author": {
        "mode": "name"
      },
      "artist": {
        "mode": "name"
      },
      "publisher": {
        "mode": "name"
      }
    },
    "genreQueryPrefix": "genre:",
    "genreTagType": "genre"
  },
  "featurePages": {
    "genreList": {
      "url": "/genre-index/",
      "pageUrl": "/genre-index/page/{page}/",
      "container": "a[href*='/genre/']",
      "fields": {
        "name": {
          "selector": "a"
        },
        "url": {
          "selector": "a",
          "attribute": "href"
        }
      }
    }
  },
  "contentIdPattern": "/manhwa/([^/]+)",
  "features": {
    "search": true,
    "randomGallery": true,
    "chapters": true,
    "favorite": true,
    "bookmark": false,
    "supportsAuth": false,
    "comments": false,
    "related": false
  }
}
