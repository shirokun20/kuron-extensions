{
  "source": "manhwaread",
  "schemaVersion": "2.0",
  "version": "1.1.0",
  "enabled": true,
  "defaultLanguage": "english",
  "baseUrl": "https://manhwaread.com",
  "configUrl": "",
  "ui": {
    "displayName": "ManhwaRead",
    "iconPath": "https://manhwaread.com/wp-content/themes/manhwaread/logo.png",
    "brandColor": "#FF6B35",
    "openInBrowserUrl": "https://manhwaread.com"
  },
  "network": {
    "requiresBypass": true,
    "cloudflare": {
      "bypassEnabled": true,
      "antiDetection": false
    },
    "headers": {
      "Referer": "https://manhwaread.com/",
      "User-Agent": "Mozilla/5.0 (Linux; Android 14) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.6099.230 Mobile Safari/537.36",
      "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
      "Accept-Language": "en-US,en;q=0.9"
    },
    "rateLimit": {
      "enabled": true,
      "requestsPerSecond": 1,
      "maxConcurrentRequests": 2
    }
  },
  "requiredPrimitives": [
    "imageMode.xhrProxy",
    "pagination.page",
    "auth.none",
    "headers.static"
  ],
  "scraper": {
    "enabled": true,
    "randomUrl": "/?random_manga=1",
    "urlPatterns": {
      "home": {
        "url": "/manhwa/",
        "list": {
          "container": ".manga-item",
          "fields": {
            "id": {
              "selector": "a[href*='/manhwa/']",
              "attribute": "href",
              "transform": "slug"
            },
            "title": {
              "selector": "h3 a[href*='/manhwa/']"
            },
            "coverUrl": {
              "selector": ".manga-item__img img, .manga-item img",
              "attribute": "src"
            }
          },
          "pagination": {
            "current": "span[aria-current='page'], .current",
            "next": "a[rel='next'], a.next",
            "prev": "a[rel='prev'], a.prev",
            "links": "a.page-numbers"
          }
        }
      },
      "homePage": {
        "url": "/manhwa/page/{page}/",
        "inherits": "home"
      },
      "search": {
        "url": "/?s={query}&post_type=wp-manga",
        "list": {
          "container": ".manga-item",
          "fields": {
            "id": {
              "selector": "a[href*='/manhwa/']",
              "attribute": "href",
              "transform": "slug"
            },
            "title": {
              "selector": "h3 a[href*='/manhwa/']"
            },
            "coverUrl": {
              "selector": ".manga-item__img img, .manga-item img",
              "attribute": "src"
            }
          },
          "pagination": {
            "current": "span[aria-current='page'], .current",
            "next": "a[rel='next'], a.next",
            "prev": "a[rel='prev'], a.prev",
            "links": "a.page-numbers"
          }
        }
      },
      "searchPage": {
        "url": "/page/{page}/?s={query}&post_type=wp-manga",
        "inherits": "search"
      },
      "genreSearch": {
        "url": "/genre/{tag}/",
        "inherits": "home"
      },
      "genreSearchPage": {
        "url": "/genre/{tag}/page/{page}/",
        "inherits": "home"
      },
      "tagSearch": {
        "url": "/tag/{tag}/",
        "inherits": "home"
      },
      "tagSearchPage": {
        "url": "/tag/{tag}/page/{page}/",
        "inherits": "home"
      },
      "authorSearch": {
        "url": "/author/{tag}/",
        "inherits": "home"
      },
      "authorSearchPage": {
        "url": "/author/{tag}/page/{page}/",
        "inherits": "home"
      },
      "artistSearch": {
        "url": "/artist/{tag}/",
        "inherits": "home"
      },
      "artistSearchPage": {
        "url": "/artist/{tag}/page/{page}/",
        "inherits": "home"
      },
      "publisherSearch": {
        "url": "/publisher/{tag}/",
        "inherits": "home"
      },
      "publisherSearchPage": {
        "url": "/publisher/{tag}/page/{page}/",
        "inherits": "home"
      },
      "detail": "/manhwa/{id}",
      "chapter": "/manhwa/{id}"
    },
    "selectors": {
      "detail": {
        "fields": {
          "title": {
            "selector": "h1.clipboard-copy"
          },
          "altTitle": {
            "selector": ".post-title h2, .alternative-title"
          },
          "coverUrl": {
            "selector": "img[src*='mancover'][src*='manhwaread-'], img[src*='mancover.xyz/cover']",
            "attribute": "src"
          },
          "description": {
            "selector": "main p, .description p, .summary__content p"
          },
          "author": {
            "selector": "a[href*='/author/']",
            "regex": "^(.*?)\\s+\\d+$"
          },
          "artist": {
            "selector": "a[href*='/artist/']",
            "regex": "^(.*?)\\s+\\d+$"
          },
          "publisher": {
            "selector": "a[href*='/publisher/']",
            "regex": "^(.*?)\\s+\\d+$"
          },
          "genres": {
            "selector": "a[href*='/genre/']",
            "multi": true
          },
          "tags": {
            "selector": "a[href*='/tag/']",
            "regex": "^(.*?)\\s+[\\d.]+K?$",
            "multi": true
          },
          "status": {
            "selector": "[class*=\"status\"]"
          },
          "rating": {
            "selector": "[class*=\"rating\"] .average, .post-ratings"
          }
        },
        "chapters": {
          "container": "#groupChapterList #chaptersList a.chapter-item",
          "fields": {
            "id": {
              "selector": "self",
              "attribute": "href",
              "regex": "/manhwa/([^/?#]+/chapter-[^/?#]+)"
            },
            "title": {
              "selector": ".chapter-item__name"
            },
            "date": {
              "selector": ".chapter-item__date"
            }
          }
        }
      },
      "reader": {
        "mode": "chapterDataScript"
      }
    }
  },
  "searchForm": {
    "urlPattern": "search",
    "params": {
      "query": {
        "queryParam": "s",
        "type": "text",
        "placeholder": "Search manhwa title..."
      },
      "sort": {
        "queryParam": "sortby",
        "type": "sort",
        "label": "Sort By",
        "options": [
          {
            "name": "Release",
            "value": "release"
          },
          {
            "name": "New",
            "value": "new"
          },
          {
            "name": "A-Z",
            "value": "alphabet"
          },
          {
            "name": "Rating",
            "value": "rating"
          },
          {
            "name": "Bookmarks",
            "value": "bookmarks"
          },
          {
            "name": "Chapters",
            "value": "chapters"
          },
          {
            "name": "Comments",
            "value": "comments"
          },
          {
            "name": "Daily Views",
            "value": "daily_top"
          },
          {
            "name": "Weekly Views",
            "value": "weekly_top"
          },
          {
            "name": "Monthly Views",
            "value": "monthly_top"
          },
          {
            "name": "Yearly Views",
            "value": "yearly_top"
          },
          {
            "name": "All Time Views",
            "value": "all_top"
          }
        ]
      },
      "order": {
        "queryParam": "order",
        "type": "select",
        "label": "Order",
        "options": [
          {
            "name": "Descending",
            "value": "desc"
          },
          {
            "name": "Ascending",
            "value": "asc"
          }
        ]
      },
      "status": {
        "queryParam": "status",
        "type": "select",
        "label": "Status",
        "options": [
          {
            "name": "Ongoing",
            "value": "ongoing"
          },
          {
            "name": "Completed",
