    "params": {
      "title": {
        "queryParam": "title",
        "type": "text",
        "placeholder": "Search manga title..."
      },
      "includedTag": {
        "queryParam": "includedTags[]",
        "type": "tag",
        "placeholder": "Choose included tags",
        "ui": {
          "selector": "picker",
          "multi": true,
          "dataSource": "mangaTags"
        }
      },
      "excludedTag": {
        "queryParam": "excludedTags[]",
        "type": "tag",
        "placeholder": "Choose excluded tags",
        "ui": {
          "selector": "picker",
          "multi": true,
          "dataSource": "mangaTags"
        }
      },
      "includedTagsMode": {
        "queryParam": "includedTagsMode",
        "type": "select",
        "options": [
          "AND",
          "OR"
        ]
      },
      "excludedTagsMode": {
        "queryParam": "excludedTagsMode",
        "type": "select",
        "options": [
          "AND",
          "OR"
        ]
      },
      "status": {
        "queryParam": "status[]",
        "type": "select",
        "options": [
          "ongoing",
          "completed",
          "hiatus",
          "cancelled"
        ]
      },
      "publicationDemographic": {
        "queryParam": "publicationDemographic[]",
        "type": "select",
        "options": [
          "shounen",
          "shoujo",
          "josei",
          "seinen",
          "none"
        ]
      },
      "contentRating": {
        "queryParam": "contentRating[]",
        "type": "select",
        "options": [
          "safe",
          "suggestive",
          "erotica",
          "pornographic"
        ]
      },
      "year": {
        "queryParam": "year",
        "type": "text",
        "placeholder": "Release year (YYYY)"
      },
      "createdAtSince": {
        "queryParam": "createdAtSince",
        "type": "text",
        "placeholder": "2025-01-01T00:00:00"
      },
      "updatedAtSince": {
        "queryParam": "updatedAtSince",
        "type": "text",
        "placeholder": "2025-01-01T00:00:00"
      },
      "sort": {
        "queryParam": "rawParam",
        "type": "select",
        "options": [
          {
            "label": "Update Date",
            "value": "order[updatedAt]=desc"
          },
          {
            "label": "Newest Added",
            "value": "order[createdAt]=desc"
          },
          {
            "label": "Latest Updated Chapter",
            "value": "order[latestUploadedChapter]=desc"
          },
          {
            "label": "title A-Z",
            "value": "order[title]=asc"
          },
          {
            "label": "title Z-A",
            "value": "order[title]=desc"
          },
          {
            "label": "The best by rating",
            "value": "order[rating]=desc"
          },
          {
            "label": "The most followed",
            "value": "order[followedCount]=desc"
          },
          {
            "label": "Relevant",
            "value": "order[relevance]=asc"
          }
        ]
      },
      "hasAvailableChapters": {
        "queryParam": "hasAvailableChapters",
        "type": "select",
        "options": [
          "true",
          "false"
        ]
      },
      "originalLanguage": {
        "queryParam": "originalLanguage[]",
        "type": "tag",
        "ui": {
          "selector": "picker",
          "multi": true,
          "dataSource": "languages"
        }
      },
      "availableTranslatedLanguage": {
        "queryParam": "availableTranslatedLanguage[]",
        "type": "tag",
        "ui": {
          "selector": "picker",
          "multi": true,
          "dataSource": "languages"
        }
      }
    }
  },
  "features": {
    "comments": false,
    "related": false,
    "favorite": true,
    "chapters": true
  },
  "navigation": {
    "tagQueryMapping": {
      "author": {
        "mode": "rawParam",
        "param": "authorOrArtist",
        "valueSource": "tagId",
        "requiredPattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
      },
      "artist": {
        "mode": "rawParam",
        "param": "authorOrArtist",
        "valueSource": "tagId",
        "requiredPattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
      },
      "demographic": {
        "mode": "rawParam",
        "param": "publicationDemographic[]",
        "valueSource": "tagName",
        "transform": "lowercase"
      },
      "group": {
        "mode": "name"
      },
      "scanlation_group": {
        "mode": "name"
      }
    }
  }
}
