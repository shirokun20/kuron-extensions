{
  "source": "mangadex",
  "version": "1.1.10",
  "enabled": true,
  "defaultLanguage": "english",
  "baseUrl": "https://api.mangadex.org",
  "ui": {
    "displayName": "MangaDex",
    "iconPath": "https://raw.githubusercontent.com/shirokun20/nhasixapp/refs/heads/master/app/images/mangadex.png",
    "brandColor": "#FF6740",
    "openInBrowserUrl": "https://mangadex.org"
  },
  "network": {
    "requiresBypass": false,
    "headers": {
      "User-Agent": "Kuron/2.0 (Mobile, Dart)"
    },
    "rateLimit": {
      "enabled": true,
      "requestsPerSecond": 1,
      "maxConcurrentRequests": 2
    }
  },
  "api": {
    "enabled": true,
    "queryRules": {
      "search": {
        "enforceMultiValueParams": {
          "availableTranslatedLanguage[]": []
        },
        "ensureParams": {
          "hasAvailableChapters": "true"
        }
      },
      "chapters": {
        "enforceMultiValueParams": {
          "translatedLanguage[]": []
        },
        "ensureMultiValueParamsIfMissing": {
          "contentRating[]": [
            "safe",
            "suggestive",
            "erotica",
            "pornographic"
          ]
        }
      }
    },
    "endpoints": {
      "allGalleries": "/manga?limit=100&offset={offset}&includes[]=cover_art&includes[]=author&includes[]=artist&contentRating[]=erotica&contentRating[]=pornographic&contentRating[]=suggestive&contentRating[]=safe&hasAvailableChapters=true&order[latestUploadedChapter]=desc",
      "search": "/manga?title={query}&limit=100&offset={offset}&includes[]=cover_art&includes[]=author&includes[]=artist&contentRating[]=erotica&contentRating[]=pornographic&contentRating[]=suggestive&contentRating[]=safe&hasAvailableChapters=true",
      "detail": "/manga/{id}?includes[]=cover_art&includes[]=author&includes[]=artist",
      "contentUrl": "https://mangadex.org/title/{id}"
    },
    "list": {
      "items": "$.data[*]",
      "pagination": {
        "offsetMode": true,
        "total": {
          "path": "$.total"
        },
        "limit": {
          "path": "$.limit"
        },
        "offset": {
          "path": "$.offset"
        },
        "pageSize": 100,
        "maxOffset": 9900
      },
      "fields": {
        "id": {
          "selector": "$.id"
        },
        "title": {
          "selector": "$.attributes.title"
        },
        "altTitles": {
          "selector": "$.attributes.altTitles"
        },
        "description": {
          "selector": "$.attributes.description"
        },
        "coverUrl": {
          "type": "coverBuilder",
          "template": "https://uploads.mangadex.org/covers/{mangaId}/{fileName}.256.jpg",
          "mangaIdPath": "$.id",
          "filenamePath": "$.relationships[?(@.type=='cover_art')].attributes.fileName"
        },
        "tags": {
          "selector": "$.attributes.tags[*].attributes.name.en",
          "multi": true
        },
        "artists": {
          "selector": "$.relationships[?(@.type=='artist')].attributes.name",
          "multi": true
        },
        "status": {
          "selector": "$.attributes.status"
        },
        "language": {
          "selector": "$.attributes.originalLanguage"
        },
        "originalLanguage": {
          "selector": "$.attributes.originalLanguage"
        },
        "availableTranslatedLanguages": {
          "selector": "$.attributes.availableTranslatedLanguages[*]",
          "multi": true
        },
        "pageCount": {
          "selector": "$.attributes.lastChapter"
        }
      }
    },
    "detail": {
      "tagRelations": {
        "sourcePath": "$.data.relationships[*]",
        "mappings": [
          {
            "relationshipType": "author",
            "tagType": "author",
            "namePath": "attributes.name",
            "idPath": "id"
          },
          {
            "relationshipType": "artist",
            "tagType": "artist",
            "namePath": "attributes.name",
            "idPath": "id",
            "appendToArtists": true
          }
        ]
      },
      "chapters": {
        "endpoint": "/chapter?manga={id}&translatedLanguage[]={language}&limit=100&order[chapter]=desc&contentRating[]=safe&contentRating[]=suggestive&contentRating[]=erotica&contentRating[]=pornographic",
        "autoPaginate": false,
        "items": "$.data[*]",
        "fallbackFields": {
          "language": "$.attributes.translatedLanguage"
        },
        "fields": {
          "id": {
            "selector": "$.id"
          },
          "chapterNum": {
            "selector": "$.attributes.chapter"
          },
          "volume": {
            "selector": "$.attributes.volume"
          },
          "scanlator": {
            "selector": "$.relationships[?(@.type=='scanlation_group')].attributes.name",
            "multi": true
          },
          "url": {
            "selector": "$.id"
          },
          "date": {
            "selector": "$.attributes.readableAt"
          },
          "language": {
            "selector": "$.attributes.translatedLanguage"
          }
        }
      },
      "fields": {
        "id": {
          "selector": "$.data.id"
        },
        "title": {
          "selector": "$.data.attributes.title"
        },
        "altTitles": {
          "selector": "$.data.attributes.altTitles"
        },
        "description": {
          "selector": "$.data.attributes.description"
        },
        "coverUrl": {
          "type": "coverBuilder",
          "template": "https://uploads.mangadex.org/covers/{mangaId}/{fileName}.256.jpg",
          "mangaIdPath": "$.data.id",
          "filenamePath": "$.data.relationships[?(@.type=='cover_art')].attributes.fileName"
        },
        "tags": {
          "selector": "$.data.attributes.tags[*].attributes.name.en",
          "multi": true
        },
        "artists": {
          "selector": "$.data.relationships[?(@.type=='artist')].attributes.name",
          "multi": true
        },
        "status": {
          "selector": "$.data.attributes.status"
        },
        "language": {
          "selector": "$.data.attributes.originalLanguage"
        },
        "originalLanguage": {
          "selector": "$.data.attributes.originalLanguage"
        },
        "availableTranslatedLanguages": {
          "selector": "$.data.attributes.availableTranslatedLanguages[*]",
          "multi": true
        },
        "pageCount": {
          "selector": "$.data.attributes.lastChapter"
        },
        "uploadDate": {
          "selector": "$.data.attributes.createdAt"
        }
      }
    },
    "statistics": {
      "followsEndpoint": "/statistics/manga/{id}",
      "followsPath": "$.statistics.{id}.follows",
      "ratingPath": "$.statistics.{id}.rating.average"
    },
    "images": {
      "mode": "atHome",
      "atHomeEndpoint": "/at-home/server/{chapterId}"
    }
  },
  "searchForm": {
    "urlPattern": "search",
    "dataSources": {
      "mangaTags": {
        "endpoint": "/manga/tag",
        "itemsPath": "data",
        "valuePath": "id",
        "labelPath": "attributes.name.en",
        "groupPath": "attributes.group"
      },
